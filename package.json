{
  "name": "copilot-sessions-keeper",
  "displayName": "Copilot Sessions Keeper",
  "description": "Automatically backs up Copilot chat sessions on the first launch of each day",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "vn",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrtuborg/copilot-sessions-keeper"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotSessionsKeeper.backupNow",
        "title": "Copilot Sessions Keeper: Backup Now"
      }
    ],
    "configuration": {
      "title": "Copilot Sessions Keeper",
      "properties": {
        "copilotSessionsKeeper.backupDir": {
          "type": "string",
          "default": "",
          "description": "Directory to store backups. Defaults to ~/copilot-sessions-keeper"
        },
        "copilotSessionsKeeper.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic daily backup on first session"
        },
        "copilotSessionsKeeper.retentionDays": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Auto-delete backups older than this many days. 0 = keep forever"
        },
        "copilotSessionsKeeper.outputJson": {
          "type": "boolean",
          "default": true,
          "description": "Also write a JSON file for each session (in addition to Markdown)"
        },
        "copilotSessionsKeeper.workspacePrefix": {
          "type": "string",
          "default": "",
          "description": "Prefix prepended to workspace wiki-links in Markdown frontmatter. e.g. 'projects/' produces [[projects/Users-vn-ws-foo]]"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "mocha --require ts-node/register 'src/test/unit/**/*.test.ts' 'src/test/integration/**/*.test.ts'",
    "test:watch": "mocha --watch --require ts-node/register 'src/test/**/*.test.ts'",
    "test:e2e": "npm run compile && node out/test/e2e/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "glob": "^13.0.6",
    "mocha": "^10.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.3.0"
  }
}
